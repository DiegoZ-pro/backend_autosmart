# Servidor
NODE_ENV=development
PORT=5000

# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_NAME=autosmart

# JWT
JWT_SECRET=tu_clave_secreta_muy_segura_aqui_cambiala_en_produccion
JWT_REFRESH_SECRET=otra_clave_secreta_para_refresh_token
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Límite de solicitudes
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Upload de archivos
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logs
LOG_LEVEL=info